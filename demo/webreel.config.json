{
  "$schema": "https://webreel.dev/schema/v1.json",
  "baseUrl": "http://localhost:3000",
  "outDir": "webreel-output/videos",
  "viewport": "macbook-pro",
  "defaultDelay": 500,
  "theme": {
    "hud": {
      "background": "rgba(0,0,0,0)",
      "color": "rgba(0,0,0,0)",
      "fontSize": 1
    }
  },
  "videos": {
    "hero": {
      "url": "/home",
      "waitFor": "[aria-label=\"Today\"]",
      "output": "hero.mp4",
      "steps": [
        { "action": "pause", "ms": 2000 },
        { "action": "screenshot", "output": "webreel-output/screenshots/01-hero.png" },
        { "action": "pause", "ms": 1200 }
      ]
    },
    "edge-notches": {
      "url": "/home",
      "waitFor": "[aria-label=\"Today\"]",
      "output": "edge-notches.mp4",
      "steps": [
        { "action": "pause", "ms": 1200 },
        { "action": "hover", "selector": "[aria-label=\"Today\"]", "delay": 1200 },
        { "action": "screenshot", "output": "webreel-output/screenshots/02-notch-today.png" },
        { "action": "hover", "selector": "[aria-label=\"Yeti\"]", "delay": 1200 },
        { "action": "screenshot", "output": "webreel-output/screenshots/03-notch-yeti.png" },
        { "action": "hover", "selector": "[aria-label=\"Docs\"]", "delay": 1200 },
        { "action": "screenshot", "output": "webreel-output/screenshots/04-notch-docs.png" },
        { "action": "moveTo", "selector": ".shell-canvas-layer", "delay": 600 }
      ]
    },
    "universal-input": {
      "url": "/home",
      "waitFor": "[aria-label=\"Today\"]",
      "output": "universal-input.mp4",
      "defaultDelay": 400,
      "steps": [
        { "action": "pause", "ms": 1200 },
        { "action": "type", "text": "lin", "charDelay": 55, "delay": 900 },
        { "action": "key", "key": "ArrowDown", "delay": 500 },
        { "action": "key", "key": "Enter", "delay": 400 },
        { "action": "pause", "ms": 600 }
      ]
    },
    "focus-radio": {
      "url": "/home",
      "waitFor": "[aria-label=\"Today\"]",
      "output": "focus-radio.mp4",
      "steps": [
        { "action": "pause", "ms": 1200 },
        { "action": "hover", "selector": ".shell-rim-hit-top", "delay": 1200 },
        { "action": "click", "text": "Media", "delay": 700 },
        { "action": "click", "text": "Fluid", "delay": 500 },
        { "action": "click", "selector": "[aria-label=\"Play\"]", "delay": 800 },
        { "action": "moveTo", "selector": ".shell-canvas-layer", "delay": 1200 },
        { "action": "wait", "selector": ".canvas-now-playing", "timeout": 8000 },
        { "action": "pause", "ms": 2500 },
        { "action": "screenshot", "output": "webreel-output/screenshots/08-now-playing.png" },
        { "action": "pause", "ms": 1500 }
      ]
    },
    "full-demo": {
      "url": "/home",
      "waitFor": "[aria-label=\"Today\"]",
      "output": "yeti-x-demo.mp4",
      "steps": [
        { "action": "pause", "ms": 2000 },
        { "action": "hover", "selector": "[aria-label=\"Today\"]", "delay": 1000 },
        { "action": "hover", "selector": "[aria-label=\"Yeti\"]", "delay": 1000 },
        { "action": "moveTo", "selector": ".shell-canvas-layer", "delay": 500 },
        { "action": "type", "text": "lin", "charDelay": 50, "delay": 800 },
        { "action": "key", "key": "ArrowDown", "delay": 400 },
        { "action": "key", "key": "Enter", "delay": 400 },
        { "action": "pause", "ms": 500 },
        { "action": "hover", "selector": ".shell-rim-hit-top", "delay": 1200 },
        { "action": "click", "text": "Media", "delay": 600 },
        { "action": "click", "text": "Fluid", "delay": 500 },
        { "action": "click", "selector": "[aria-label=\"Play\"]", "delay": 700 },
        { "action": "moveTo", "selector": ".shell-canvas-layer", "delay": 1200 },
        { "action": "wait", "selector": ".canvas-now-playing", "timeout": 8000 },
        { "action": "pause", "ms": 2500 }
      ]
    }
  }
}
